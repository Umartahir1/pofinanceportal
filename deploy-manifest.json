{
  "version": 1,
  "framework": {
    "name": "custom-express",
    "version": "1.0.0"
  },
  "routes": [
    {
      "path": "/*",
      "target": {
        "kind": "Compute",
        "src": "default"
      }
    }
  ],
  "computeResources": [
    {
      "name": "default",
      "runtime": "nodejs22.x",
      "entrypoint": "server.js"
    }
  ]
}
